getwd()
getwd()
infra_institution <- read.csv(
"data/raw/infra_institution.csv",
fileEncoding = "CP949"
)
infra_institution <- read.csv(
"data/raw/infra_institution.csv",
fileEncoding = "CP949",
header = FALSE
)
View(infra_institution)
infra_institution <- read.csv(
"data/raw/infra_institution.csv",
fileEncoding = "UTF-8",
header = FALSE
)
View(infra_institution)
names(infra_institution) <- c("region", "item", "unit", "institution_count")
infra_institution_clean <- infra_institution[-1, ]
infra_institution_clean$institution_count <- as.numeric(infra_institution_clean$institution_count)
head(infra_institution_clean)
str(infra_institution_clean)
infra_institution_sum <- aggregate(
institution_count ~ region,
data = infra_institution_clean,
sum
)
infra_institution_sum$area_group <- ifelse(
infra_institution_sum$region %in% c("서울", "경기", "인천"),
"수도권",
"비수도권"
)
head(infra_institution_sum)
str(infra_institution_sum)
write.csv(
infra_institution_sum,
"data/processed/infra_institution_sum.csv",
row.names = FALSE
)
boxplot(
institution_count ~ area_group,
data = infra_institution_sum,
main = "수도권 vs 비수도권 응급의료기관 수 비교",
xlab = "지역 그룹",
ylab = "응급의료기관 수"
)
infra_institution <- read.csv(
"data/raw/infra_institution.csv",
fileEncoding = "UTF-8",
header = FALSE
)
View(infra_institution)
names(infra_institution) <- c(
"region",
"item",
"unit",
"institution_count"
)
# 첫 행 제거
infra_institution_clean <- infra_institution[-1, ]
# 숫자형 변환
infra_institution_clean$institution_count <- as.numeric(
infra_institution_clean$institution_count
)
# 데이터 확인
head(infra_institution_clean)
str(infra_institution_clean)
infra_institution_sum <- aggregate(
institution_count ~ region,
data = infra_institution_clean,
sum
)
infra_institution_sum$area_group <- ifelse(
infra_institution_sum$region %in% c("서울", "경기", "인천"),
"수도권",
"비수도권"
)
# 데이터 확인
head(infra_institution_sum)
str(infra_institution_sum)
write.csv(
infra_institution_sum,
"data/processed/infra_institution_sum.csv",
row.names = FALSE
)
boxplot(
institution_count ~ area_group,
data = infra_institution_sum,
main = "수도권 vs 비수도권 응급의료기관 수 비교",
xlab = "지역 그룹",
ylab = "응급의료기관 수"
)
infra_bed <- read.csv(
"data/raw/infra_bed.csv",
fileEncoding = "UTF-8",
header = FALSE
)
View(infra_bed)
head(infra_bed)
names(infra_bed)
str(infra_bed)
infra_bed_clean <- infra_bed[-1, ]
infra_bed_total <- subset(
infra_bed_clean,
item == "전체"
)
names(infra_bed)
names(infra_bed) <- c(
"region",
"item",
"unit",
"bed_count"
)
infra_bed_clean <- infra_bed[-1, ]
names(infra_bed)
infra_bed_total <- subset(
infra_bed_clean,
item == "전체"
)
infra_bed_total$bed_count <- as.numeric(
gsub(",", "", infra_bed_total$bed_count)
)
infra_bed_total$area_group <- ifelse(
infra_bed_total$region %in% c("서울", "경기", "인천"),
"수도권",
"비수도권"
)
head(infra_bed_total)
str(infra_bed_total)
names(infra_bed)
###
# 정리본 저장
###
write.csv(
infra_bed_total,
"data/processed/infra_bed_total.csv",
row.names = FALSE
)
###
# 시각화
###
boxplot(
bed_count ~ area_group,
data = infra_bed_total,
main = "수도권 vs 비수도권 응급의료기관 병상 수 비교",
xlab = "지역 그룹",
ylab = "병상 수"
)
barplot(
infra_bed_total$bed_count,
names.arg = infra_bed_total$region,
main = "지역별 응급의료기관 병상 수",
ylab = "병상 수",
las = 2
)
